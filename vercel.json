{
  "version": 2,
  "functions": {
    "api/analyze-doc.js": { "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*\\.(png|jpg|jpeg|gif|ico|svg|webp|css|js|woff|woff2|ttf|pdf))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
